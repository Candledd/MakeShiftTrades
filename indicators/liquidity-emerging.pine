//@version=6
indicator('Liquidity Engulfing (Nephew_Sam_)', overlay = true, dynamic_requests = true)

// =============================================================================
// INPUT SETTINGS
// =============================================================================


// Timeframe inputs with default values
var settings = 'Settings'
filter_engulfing = input.bool(false, title = 'Filter Engulfing', group = settings, tooltip = 'If enabled, the engulfing pattern will be filtered to only show when the previous candle is bullish or bearish')


var timeframes = 'Timeframes'
tf1_enabled = input.bool(true, title = '', group = timeframes, inline = '1')
tf1 = input.timeframe('', title = 'TF 1: ', group = timeframes, inline = '1')
tf1_enable_fib = input.bool(false, title = 'Show Fib', group = timeframes, inline = '1')

tf2_enabled = input.bool(true, title = '', group = timeframes, inline = '2')
tf2 = input.timeframe('60', title = 'TF 2: ', group = timeframes, inline = '2')
tf2_enable_fib = input.bool(false, title = 'Show Fib', group = timeframes, inline = '2')

tf3_enabled = input.bool(true, title = '', group = timeframes, inline = '3')
tf3 = input.timeframe('120', title = 'TF 3: ', group = timeframes, inline = '3')
tf3_enable_fib = input.bool(false, title = 'Show Fib', group = timeframes, inline = '3')

tf4_enabled = input.bool(true, title = '', group = timeframes, inline = '4')
tf4 = input.timeframe('240', title = 'TF 4: ', group = timeframes, inline = '4')
tf4_enable_fib = input.bool(false, title = 'Show Fib', group = timeframes, inline = '4')

tf5_enabled = input.bool(true, title = '', group = timeframes, inline = '5')
tf5 = input.timeframe('D', title = 'TF 5: ', group = timeframes, inline = '5')
tf5_enable_fib = input.bool(false, title = 'Show Fib', group = timeframes, inline = '5')

tf6_enabled = input.bool(false, title = '', group = timeframes, inline = '6')
tf6 = input.timeframe('W', title = 'TF 6: ', group = timeframes, inline = '6')
tf6_enable_fib = input.bool(false, title = 'Show Fib', group = timeframes, inline = '6')


// Fib settings
var fib_settings = 'Fib Settings'
keep_previous_fibs = input.bool(false, title = 'Keep Previous Fib Lines', group = fib_settings)
show_timeframe_fib_label = input.bool(false, title = 'Show Timeframe Label', group = fib_settings)
extend_fib_lines = input.bool(false, title = 'Extend Fib Lines', group = fib_settings)

fib_0_color = input.color(color.new(color.green, 0), title = '0% - Line Color', group = fib_settings, inline = '1')
fib_0_line_style = input.string('Solid', title = 'Style', options = ['Solid', 'Dashed', 'Dotted'], group = fib_settings, inline = '1')

fib_25_color = input.color(color.new(color.green, 0), title = '25% - Line Color', group = fib_settings, inline = '2')
fib_25_line_style = input.string('Dotted', title = 'Style', options = ['Solid', 'Dashed', 'Dotted'], group = fib_settings, inline = '2')


fib_50_color = input.color(color.new(color.gray, 0), title = '50% - Line Color', group = fib_settings, inline = '3')
fib_50_line_style = input.string('Dashed', title = 'Style', options = ['Solid', 'Dashed', 'Dotted'], group = fib_settings, inline = '3')


fib_75_color = input.color(color.new(color.red, 0), title = '75% - Line Color', group = fib_settings, inline = '4')
fib_75_line_style = input.string('Dotted', title = 'Style', options = ['Solid', 'Dashed', 'Dotted'], group = fib_settings, inline = '4')

fib_100_color = input.color(color.new(color.red, 0), title = '100% - Line Color', group = fib_settings, inline = '5')
fib_100_line_style = input.string('Solid', title = 'Style', options = ['Solid', 'Dashed', 'Dotted'], group = fib_settings, inline = '5')

// Bar Color Settings
var barColorGroup = 'Bar Color Settings'
change_bar_color = input.bool(true, 'Change Bar Color', group = barColorGroup)
bull_bar_color = input.color(color.new(color.green, 100), 'Bullish Color', group = barColorGroup)
bear_bar_color = input.color(color.new(color.red, 100), 'Bearish Color', group = barColorGroup)

// Table position settings
var tableGroup = 'Table Settings'
enable_table = input.bool(true, 'Enable Table', group = tableGroup)
table_position = input.string('middle_right', title = 'Table Position', options = ['top_left', 'top_center', 'top_right', 'middle_left', 'middle_center', 'middle_right', 'bottom_left', 'bottom_center', 'bottom_right'], group = tableGroup)
table_text_size = input.string('small', title = 'Text Size', options = ['large', 'normal', 'small', 'tiny'], group = tableGroup)
table_show_header = input.bool(false, 'Show Table Header', group = tableGroup)
table_text_color = input.color(color.white, 'Table Text Color', group = tableGroup)
table_bull_bg = input.color(color.green, 'Bull background', group = tableGroup, inline = '1')
table_bear_bg = input.color(color.red, '| Bear background', group = tableGroup, inline = '1')

var debuggingGroup = 'Debugging'
chartId = input.string("abcd1234", "Chart ID:)", group="Debugging")
enable_debug_labels = input.bool(false, 'Show TF3 Debug Labels', group = debuggingGroup)

// =============================================================================
// ENGULFING DETECTION FUNCTIONS
// =============================================================================

// Function to detect bullish engulfing pattern
is_bullish_engulfing() =>
    // 1. Current candle must be bullish (close > open)
    current_bullish = close > open
    // 2. Previous candle must be bearish (close < open)  
    previous_bearish = filter_engulfing ? close[1] < open[1] : true
    // 3. Current low is lower than previous low
    current_low_below_prev_low = low < low[1]
    // 4. Current close is higher than previous open
    current_close_above_prev_open = close > open[1]

    current_bullish and previous_bearish and current_low_below_prev_low and current_close_above_prev_open

// Function to detect bearish engulfing pattern  
is_bearish_engulfing() =>
    // 1. Current candle must be bearish (close < open)
    current_bearish = close < open
    // 2. Previous candle must be bullish (close > open)
    previous_bullish = filter_engulfing ? close[1] > open[1] : true
    // 3. Current high is higher than previous high
    current_high_above_prev_high = high > high[1]
    // 4. Current close is lower than previous open
    current_close_below_prev_open = close < open[1]

    current_bearish and previous_bullish and current_high_above_prev_high and current_close_below_prev_open

// Function to get engulfing data for a timeframe (current and previous)
get_engulfing_data() =>
    // Current engulfing patterns
    bull_engulf = is_bullish_engulfing()
    bear_engulf = is_bearish_engulfing()
    
    // Previous engulfing patterns (within the timeframe context)
    bull_engulf_prev = is_bullish_engulfing()[1]
    bear_engulf_prev = is_bearish_engulfing()[1]
    
    [bull_engulf, bear_engulf, bull_engulf_prev, bear_engulf_prev]

// =============================================================================
// TIMEFRAME VALIDATION FUNCTIONS
// =============================================================================

// Function to convert timeframe string to minutes for comparison
timeframe_to_minutes(tf_string) =>
    if tf_string == '' or tf_string == 'chart'
        timeframe.in_seconds() / 60
    else if tf_string == '1'
        1
    else if tf_string == '5'
        5
    else if tf_string == '15'
        15
    else if tf_string == '30'
        30
    else if tf_string == '60'
        60
    else if tf_string == '240'
        240
    else if tf_string == 'D'
        1440 // 24 hours * 60 minutes
    else if tf_string == 'W'
        10080 // 7 days * 24 hours * 60 minutes
    else if tf_string == 'M'
        43200 // Approximate 30 days * 24 hours * 60 minutes
    else // Try to parse as number for custom timeframes
        not na(str.tonumber(tf_string)) ? str.tonumber(tf_string) : timeframe.in_seconds() / 60

// Function to check if a timeframe is higher than current chart timeframe
is_higher_timeframe(tf_string) =>
    current_tf_minutes = timeframe.in_seconds() / 60
    target_tf_minutes = timeframe_to_minutes(tf_string)
    target_tf_minutes >= current_tf_minutes

// =============================================================================
// MAIN DETECTION LOGIC (MULTI-TIMEFRAME)
// =============================================================================

// Get engulfing data for all timeframes (current and previous in single call)
// TF1 - always get if enabled
[tf1_bull_engulf, tf1_bear_engulf, tf1_bull_engulf_prev, tf1_bear_engulf_prev] = if tf1_enabled
    request.security(syminfo.tickerid, tf1, get_engulfing_data(), lookahead=barmerge.lookahead_on)
else
    [false, false, false, false]

// TF2 - get both current and previous higher timeframe data
[tf2_bull_engulf, tf2_bear_engulf, tf2_bull_engulf_prev, tf2_bear_engulf_prev] = if tf2_enabled and is_higher_timeframe(tf2)
    request.security(syminfo.tickerid, tf2, get_engulfing_data(), lookahead=barmerge.lookahead_on)
else
    [false, false, false, false]

// TF3 - get both current and previous higher timeframe data
[tf3_bull_engulf, tf3_bear_engulf, tf3_bull_engulf_prev, tf3_bear_engulf_prev] = if tf3_enabled and is_higher_timeframe(tf3)
    request.security(syminfo.tickerid, tf3, get_engulfing_data(), lookahead=barmerge.lookahead_on)
else
    [false, false, false, false]

// TF4 - get both current and previous higher timeframe data
[tf4_bull_engulf, tf4_bear_engulf, tf4_bull_engulf_prev, tf4_bear_engulf_prev] = if tf4_enabled and is_higher_timeframe(tf4)
    request.security(syminfo.tickerid, tf4, get_engulfing_data(), lookahead=barmerge.lookahead_on)
else
    [false, false, false, false]

// TF5 - get both current and previous higher timeframe data
[tf5_bull_engulf, tf5_bear_engulf, tf5_bull_engulf_prev, tf5_bear_engulf_prev] = if tf5_enabled and is_higher_timeframe(tf5)
    request.security(syminfo.tickerid, tf5, get_engulfing_data(), lookahead=barmerge.lookahead_on)
else
    [false, false, false, false]

// TF6 - get both current and previous higher timeframe data
[tf6_bull_engulf, tf6_bear_engulf, tf6_bull_engulf_prev, tf6_bear_engulf_prev] = if tf6_enabled and is_higher_timeframe(tf6)
    request.security(syminfo.tickerid, tf6, get_engulfing_data(), lookahead=barmerge.lookahead_on)
else
    [false, false, false, false]

// =============================================================================
// ENHANCED DETECTION LOGIC (MULTI-TIMEFRAME)
// =============================================================================

// Detect confirmed and unconfirmed engulfing for all timeframes
// TF1 - For chart timeframe, use standard previous/current logic
tf1_bull_confirmed = tf1_bull_engulf_prev  // Previous chart candle (confirmed)
tf1_bear_confirmed = tf1_bear_engulf_prev  // Previous chart candle (confirmed)
tf1_bull_unconfirmed = tf1_bull_engulf     // Current chart candle (unconfirmed)
tf1_bear_unconfirmed = tf1_bear_engulf     // Current chart candle (unconfirmed)
has_tf1_engulfing = tf1_enabled and (tf1_bull_confirmed or tf1_bear_confirmed or tf1_bull_unconfirmed or tf1_bear_unconfirmed)

// TF2 - Check both current and previous higher timeframe candles
tf2_bull_confirmed = tf2_bull_engulf_prev  // Previous higher TF candle (confirmed)
tf2_bear_confirmed = tf2_bear_engulf_prev  // Previous higher TF candle (confirmed)
tf2_bull_unconfirmed = tf2_bull_engulf     // Current higher TF candle (unconfirmed)
tf2_bear_unconfirmed = tf2_bear_engulf     // Current higher TF candle (unconfirmed)
has_tf2_engulfing = tf2_enabled and is_higher_timeframe(tf2) and (tf2_bull_confirmed or tf2_bear_confirmed or tf2_bull_unconfirmed or tf2_bear_unconfirmed)

// TF3 - Check both current and previous higher timeframe candles
tf3_bull_confirmed = tf3_bull_engulf_prev  // Previous higher TF candle (confirmed)
tf3_bear_confirmed = tf3_bear_engulf_prev  // Previous higher TF candle (confirmed)
tf3_bull_unconfirmed = tf3_bull_engulf     // Current higher TF candle (unconfirmed)
tf3_bear_unconfirmed = tf3_bear_engulf     // Current higher TF candle (unconfirmed)
has_tf3_engulfing = tf3_enabled and is_higher_timeframe(tf3) and (tf3_bull_confirmed or tf3_bear_confirmed or tf3_bull_unconfirmed or tf3_bear_unconfirmed)

// TF4 - Check both current and previous higher timeframe candles
tf4_bull_confirmed = tf4_bull_engulf_prev  // Previous higher TF candle (confirmed)
tf4_bear_confirmed = tf4_bear_engulf_prev  // Previous higher TF candle (confirmed)
tf4_bull_unconfirmed = tf4_bull_engulf     // Current higher TF candle (unconfirmed)
tf4_bear_unconfirmed = tf4_bear_engulf     // Current higher TF candle (unconfirmed)
has_tf4_engulfing = tf4_enabled and is_higher_timeframe(tf4) and (tf4_bull_confirmed or tf4_bear_confirmed or tf4_bull_unconfirmed or tf4_bear_unconfirmed)

// TF5 - Check both current and previous higher timeframe candles
tf5_bull_confirmed = tf5_bull_engulf_prev  // Previous higher TF candle (confirmed)
tf5_bear_confirmed = tf5_bear_engulf_prev  // Previous higher TF candle (confirmed)
tf5_bull_unconfirmed = tf5_bull_engulf     // Current higher TF candle (unconfirmed)
tf5_bear_unconfirmed = tf5_bear_engulf     // Current higher TF candle (unconfirmed)
has_tf5_engulfing = tf5_enabled and is_higher_timeframe(tf5) and (tf5_bull_confirmed or tf5_bear_confirmed or tf5_bull_unconfirmed or tf5_bear_unconfirmed)

// TF6 - Check both current and previous higher timeframe candles
tf6_bull_confirmed = tf6_bull_engulf_prev  // Previous higher TF candle (confirmed)
tf6_bear_confirmed = tf6_bear_engulf_prev  // Previous higher TF candle (confirmed)
tf6_bull_unconfirmed = tf6_bull_engulf     // Current higher TF candle (unconfirmed)
tf6_bear_unconfirmed = tf6_bear_engulf     // Current higher TF candle (unconfirmed)
has_tf6_engulfing = tf6_enabled and is_higher_timeframe(tf6) and (tf6_bull_confirmed or tf6_bear_confirmed or tf6_bull_unconfirmed or tf6_bear_unconfirmed)

// Check if we have any engulfing across all timeframes
has_any_engulfing = has_tf1_engulfing or has_tf2_engulfing or has_tf3_engulfing or has_tf4_engulfing or has_tf5_engulfing or has_tf6_engulfing

// =============================================================================
// TABLE MANAGEMENT
// =============================================================================

// Function to get table position
get_table_position(pos_string) =>
    switch pos_string
        'top_left' => position.top_left
        'top_center' => position.top_center
        'top_right' => position.top_right
        'middle_left' => position.middle_left
        'middle_center' => position.middle_center
        'middle_right' => position.middle_right
        'bottom_left' => position.bottom_left
        'bottom_center' => position.bottom_center
        'bottom_right' => position.bottom_right
        => position.top_right

// Function to get text size from string
get_text_size(size_string) =>
    switch size_string
        'large' => size.large
        'normal' => size.normal
        'small' => size.small
        'tiny' => size.tiny
        => size.normal

// Function to format timeframe for display
format_timeframe(tf_str) =>
    // Handle empty string or "chart" - both represent current chart timeframe
    if tf_str == '' or tf_str == 'chart'
        current_tf_minutes = timeframe.in_seconds() / 60
        if current_tf_minutes < 1
            str.tostring(current_tf_minutes * 60) + 's'
        else if current_tf_minutes < 60
            str.tostring(current_tf_minutes) + 'm'
        else if current_tf_minutes < 1440
            hours = current_tf_minutes / 60
            str.tostring(hours) + 'h'
        else if current_tf_minutes >= 1440 and current_tf_minutes < 10080
            days = current_tf_minutes / 1440
            str.tostring(days) + 'd'
        else
            timeframe.period
    else
        tf_num = str.tonumber(tf_str)
        if not na(tf_num)
            if tf_num < 1
                str.tostring(tf_num * 60) + 's'
            else if tf_num < 60
                str.tostring(tf_num) + 'm'
            else if tf_num < 1440
                hours = tf_num / 60
                str.tostring(hours) + 'h'
            else if tf_num >= 1440 and tf_num < 10080
                days = tf_num / 1440
                str.tostring(days) + 'D'
            else
                tf_str
        else
            tf_str == 'D' ? '1d' : tf_str == "3D" ? '3d' : tf_str == 'W' ? '1w' : tf_str == 'M' ? '1M' : tf_str


// Function to check if a timeframe matches the chart timeframe
is_chart_timeframe(tf_string) =>
    if tf_string == '' or tf_string == 'chart'
        true
    else
        tf_string == timeframe.period

// Function to check if a timeframe conflicts with tf1 (chart timeframe)
has_tf1_conflict(tf_string) =>
    tf1_enabled and is_chart_timeframe(tf1) and is_chart_timeframe(tf_string)

// Function to get background color for timeframe
get_tf_bg_color(bull_confirmed, bear_confirmed, bull_unconfirmed, bear_unconfirmed) =>
    if bull_confirmed
        table_bull_bg // Full opacity for confirmed
    else if bear_confirmed
        table_bear_bg // Full opacity for confirmed
    else if bull_unconfirmed
        color.new(table_bull_bg, 50) // 50% opacity for unconfirmed
    else if bear_unconfirmed
        color.new(table_bear_bg, 50) // 50% opacity for unconfirmed
    else
        na

// Create and manage multi-timeframe table
var table engulfing_table = na

// Count enabled timeframes (excluding conflicts with tf1)
enabled_rows = 0
if tf1_enabled
    enabled_rows := enabled_rows + 1
if tf2_enabled and is_higher_timeframe(tf2) and not has_tf1_conflict(tf2)
    enabled_rows := enabled_rows + 1
if tf3_enabled and is_higher_timeframe(tf3) and not has_tf1_conflict(tf3)
    enabled_rows := enabled_rows + 1
if tf4_enabled and is_higher_timeframe(tf4) and not has_tf1_conflict(tf4)
    enabled_rows := enabled_rows + 1
if tf5_enabled and is_higher_timeframe(tf5) and not has_tf1_conflict(tf5)
    enabled_rows := enabled_rows + 1
if tf6_enabled and is_higher_timeframe(tf6) and not has_tf1_conflict(tf6)
    enabled_rows := enabled_rows + 1

// Create new table (always show if there are enabled timeframes)
if enabled_rows > 0 and enable_table
    // Delete existing table
    if not na(engulfing_table)
        table.delete(engulfing_table)

    // Create new table with EBP title row + enabled timeframes + optional header
    columns = 2
    rows = 1 + enabled_rows + (table_show_header ? 1 : 0) // EBP title + timeframes + optional header
    engulfing_table := table.new(get_table_position(table_position), columns, rows, bgcolor = color.new(color.black, 80), border_width = 1)

    // Add EBP title row (always first)
    table.cell(engulfing_table, 0, 0, 'EBP', text_color = table_text_color, text_size = get_text_size(table_text_size), bgcolor = color.new(color.black, 70))
    table.merge_cells(engulfing_table, 0, 0, 1, 0)
    row_index = 1

    // Add header if enabled
    if table_show_header
        table.cell(engulfing_table, 0, row_index, 'Timeframe', text_color = table_text_color, text_size = get_text_size(table_text_size))
        table.cell(engulfing_table, 1, row_index, 'Status', text_color = table_text_color, text_size = get_text_size(table_text_size))
        row_index := row_index + 1

    // Add TF1 row if enabled
    if tf1_enabled
        tf1_display = format_timeframe(tf1)
        tf1_bg_color = get_tf_bg_color(tf1_bull_confirmed, tf1_bear_confirmed, tf1_bull_unconfirmed, tf1_bear_unconfirmed)
        table.cell(engulfing_table, 0, row_index, tf1_display, text_color = table_text_color, text_size = get_text_size(table_text_size), bgcolor = color.new(color.black, 90))
        table.cell(engulfing_table, 1, row_index, '', bgcolor = tf1_bg_color)
        row_index := row_index + 1

    // Add TF2 row if enabled
    if tf2_enabled and is_higher_timeframe(tf2) and not has_tf1_conflict(tf2)
        tf2_display = format_timeframe(tf2)
        tf2_bg_color = get_tf_bg_color(tf2_bull_confirmed, tf2_bear_confirmed, tf2_bull_unconfirmed, tf2_bear_unconfirmed)
        table.cell(engulfing_table, 0, row_index, tf2_display, text_color = table_text_color, text_size = get_text_size(table_text_size), bgcolor = color.new(color.black, 90))
        table.cell(engulfing_table, 1, row_index, '', bgcolor = tf2_bg_color)
        row_index := row_index + 1

    // Add TF3 row if enabled
    if tf3_enabled and is_higher_timeframe(tf3) and not has_tf1_conflict(tf3)
        tf3_display = format_timeframe(tf3)
        tf3_bg_color = get_tf_bg_color(tf3_bull_confirmed, tf3_bear_confirmed, tf3_bull_unconfirmed, tf3_bear_unconfirmed)
        table.cell(engulfing_table, 0, row_index, tf3_display, text_color = table_text_color, text_size = get_text_size(table_text_size), bgcolor = color.new(color.black, 90))
        table.cell(engulfing_table, 1, row_index, '', bgcolor = tf3_bg_color)
        row_index := row_index + 1

    // Add TF4 row if enabled
    if tf4_enabled and is_higher_timeframe(tf4) and not has_tf1_conflict(tf4)
        tf4_display = format_timeframe(tf4)
        tf4_bg_color = get_tf_bg_color(tf4_bull_confirmed, tf4_bear_confirmed, tf4_bull_unconfirmed, tf4_bear_unconfirmed)
        table.cell(engulfing_table, 0, row_index, tf4_display, text_color = table_text_color, text_size = get_text_size(table_text_size), bgcolor = color.new(color.black, 90))
        table.cell(engulfing_table, 1, row_index, '', bgcolor = tf4_bg_color)
        row_index := row_index + 1

    // Add TF5 row if enabled
    if tf5_enabled and is_higher_timeframe(tf5) and not has_tf1_conflict(tf5)
        tf5_display = format_timeframe(tf5)
        tf5_bg_color = get_tf_bg_color(tf5_bull_confirmed, tf5_bear_confirmed, tf5_bull_unconfirmed, tf5_bear_unconfirmed)
        table.cell(engulfing_table, 0, row_index, tf5_display, text_color = table_text_color, text_size = get_text_size(table_text_size), bgcolor = color.new(color.black, 90))
        table.cell(engulfing_table, 1, row_index, '', bgcolor = tf5_bg_color)
        row_index := row_index + 1

    // Add TF6 row if enabled
    if tf6_enabled and is_higher_timeframe(tf6) and not has_tf1_conflict(tf6)
        tf6_display = format_timeframe(tf6)
        tf6_bg_color = get_tf_bg_color(tf6_bull_confirmed, tf6_bear_confirmed, tf6_bull_unconfirmed, tf6_bear_unconfirmed)
        table.cell(engulfing_table, 0, row_index, tf6_display, text_color = table_text_color, text_size = get_text_size(table_text_size), bgcolor = color.new(color.black, 90))
        table.cell(engulfing_table, 1, row_index, '', bgcolor = tf6_bg_color)
        row_index := row_index + 1

// Delete table if disabled or no enabled timeframes
else
    if not na(engulfing_table)
        table.delete(engulfing_table)
        engulfing_table := na

// =============================================================================
// VISUAL ELEMENTS (BAR COLORING ONLY)
// =============================================================================

// Change bar color only if: setting enabled AND engulfing found AND timeframe matches chart
// Handle empty string case (empty string means current timeframe)
is_current_tf = tf1 == '' or tf1 == timeframe.period
bullish_bar_condition = change_bar_color and tf1_bull_engulf and is_current_tf
bearish_bar_condition = change_bar_color and tf1_bear_engulf and is_current_tf

barcolor(bullish_bar_condition ? bull_bar_color : bearish_bar_condition ? bear_bar_color : na, title = 'Engulfing Bar Color')



// =============================================================================
// DEBUG LABEL FOR TF3 TESTING
// =============================================================================

// Create debug label to test TF3 engulfing detection
if enable_debug_labels and tf3_enabled and is_higher_timeframe(tf3)
    debug_text = ""
    debug_color = color.gray
    
    // Check current and previous TF3 status
    if tf3_bull_engulf and tf3_bull_engulf_prev
        debug_text := "TF3: CURR+PREV BULL"
        debug_color := color.green
    else if tf3_bull_engulf
        debug_text := "TF3: CURRENT BULL"
        debug_color := color.lime
    else if tf3_bull_engulf_prev
        debug_text := "TF3: PREVIOUS BULL"
        debug_color := color.green
    else if tf3_bear_engulf and tf3_bear_engulf_prev
        debug_text := "TF3: CURR+PREV BEAR"
        debug_color := color.red
    else if tf3_bear_engulf
        debug_text := "TF3: CURRENT BEAR"
        debug_color := color.orange
    else if tf3_bear_engulf_prev
        debug_text := "TF3: PREVIOUS BEAR"
        debug_color := color.red
    else
        debug_text := "TF3: NO ENGULF"
        debug_color := color.gray
    
    // Show timeframe info
    tf3_display = format_timeframe(tf3)
    full_debug_text = tf3_display + "\n" + debug_text
    
    // Create debug label
    label.new(bar_index, low, text=full_debug_text, 
             style=label.style_label_up, color=debug_color, 
             textcolor=color.white, size=size.small)

// =============================================================================
// MULTI-TIMEFRAME FIBONACCI RETRACEMENT SYSTEM
// =============================================================================

// Function to convert line style string to Pine Script line style
get_line_style(style_string) =>
    switch style_string
        'Solid' => line.style_solid
        'Dashed' => line.style_dashed
        'Dotted' => line.style_dotted
        => line.style_solid

// Fibonacci arrays for all timeframes
var array<line> tf1_fib_lines = array.new<line>()
var array<label> tf1_fib_labels = array.new<label>()
var array<line> tf2_fib_lines = array.new<line>()
var array<label> tf2_fib_labels = array.new<label>()
var array<line> tf3_fib_lines = array.new<line>()
var array<label> tf3_fib_labels = array.new<label>()
var array<line> tf4_fib_lines = array.new<line>()
var array<label> tf4_fib_labels = array.new<label>()
var array<line> tf5_fib_lines = array.new<line>()
var array<label> tf5_fib_labels = array.new<label>()
var array<line> tf6_fib_lines = array.new<line>()
var array<label> tf6_fib_labels = array.new<label>()

// Variables to track if we've already drawn fibs for current engulfing
var bool tf1_fib_drawn = false
var bool tf2_fib_drawn = false  
var bool tf3_fib_drawn = false
var bool tf4_fib_drawn = false
var bool tf5_fib_drawn = false
var bool tf6_fib_drawn = false

// Function to safely delete previous fibonacci lines
delete_fib_lines(fib_lines, fib_labels) =>
    if not keep_previous_fibs
        // Only iterate if array has elements
        if array.size(fib_lines) > 0
            for i = 0 to array.size(fib_lines) - 1
                line.delete(array.get(fib_lines, i))
        array.clear(fib_lines)
        
        // Only iterate if array has elements  
        if array.size(fib_labels) > 0
            for i = 0 to array.size(fib_labels) - 1
                label.delete(array.get(fib_labels, i))
        array.clear(fib_labels)

// Function to get OHLC and timing data for fibonacci calculation
get_fib_data() =>
    [open, high, low, close, time, time_close]

// Get fibonacci data for all enabled timeframes
[tf1_fib_open, tf1_fib_high, tf1_fib_low, tf1_fib_close, tf1_fib_time, tf1_fib_time_close] = if tf1_enabled
    request.security(syminfo.tickerid, tf1, get_fib_data(), lookahead=barmerge.lookahead_on)
else
    [open, high, low, close, time, time_close]

[tf2_fib_open, tf2_fib_high, tf2_fib_low, tf2_fib_close, tf2_fib_time, tf2_fib_time_close] = if tf2_enabled and is_higher_timeframe(tf2)
    request.security(syminfo.tickerid, tf2, get_fib_data(), lookahead=barmerge.lookahead_on)
else
    [open, high, low, close, time, time_close]

[tf3_fib_open, tf3_fib_high, tf3_fib_low, tf3_fib_close, tf3_fib_time, tf3_fib_time_close] = if tf3_enabled and is_higher_timeframe(tf3)
    request.security(syminfo.tickerid, tf3, get_fib_data(), lookahead=barmerge.lookahead_on)
else
    [open, high, low, close, time, time_close]

[tf4_fib_open, tf4_fib_high, tf4_fib_low, tf4_fib_close, tf4_fib_time, tf4_fib_time_close] = if tf4_enabled and is_higher_timeframe(tf4)
    request.security(syminfo.tickerid, tf4, get_fib_data(), lookahead=barmerge.lookahead_on)
else
    [open, high, low, close, time, time_close]

[tf5_fib_open, tf5_fib_high, tf5_fib_low, tf5_fib_close, tf5_fib_time, tf5_fib_time_close] = if tf5_enabled and is_higher_timeframe(tf5)
    request.security(syminfo.tickerid, tf5, get_fib_data(), lookahead=barmerge.lookahead_on)
else
    [open, high, low, close, time, time_close]

[tf6_fib_open, tf6_fib_high, tf6_fib_low, tf6_fib_close, tf6_fib_time, tf6_fib_time_close] = if tf6_enabled and is_higher_timeframe(tf6)
    request.security(syminfo.tickerid, tf6, get_fib_data(), lookahead=barmerge.lookahead_on)
else
    [open, high, low, close, time, time_close]

// Function to create fibonacci retracement lines with proper MTF timing
create_fibonacci_lines(is_bullish, fib_high, fib_low, start_time, end_time, tf_string, fib_lines, fib_labels) =>
    // Delete previous lines if not keeping them
    delete_fib_lines(fib_lines, fib_labels)
    
    // Calculate fibonacci levels
    price_range = fib_high - fib_low
    
    // Declare fibonacci level variables
    fib_0 = 0.0
    fib_25 = 0.0
    fib_50 = 0.0
    fib_75 = 0.0
    fib_100 = 0.0
    
    // Set fibonacci levels based on bullish/bearish orientation
    if is_bullish
        // Bullish engulfing: 0% = low, 100% = high
        fib_0 := fib_low
        fib_25 := fib_low + (price_range * 0.25)
        fib_50 := fib_low + (price_range * 0.50)
        fib_75 := fib_low + (price_range * 0.75)
        fib_100 := fib_high
    else
        // Bearish engulfing: 0% = high, 100% = low
        fib_0 := fib_high
        fib_25 := fib_high - (price_range * 0.25)
        fib_50 := fib_high - (price_range * 0.50)
        fib_75 := fib_high - (price_range * 0.75)
        fib_100 := fib_low
    
    // Determine line extension and end point
    line_extend = extend_fib_lines ? extend.right : extend.none
    
    // Create the 5 fibonacci levels
    // 0% Line
    line_0 = line.new(start_time, fib_0, end_time, fib_0, 
                     color=fib_0_color, style=get_line_style(fib_0_line_style), 
                     extend=line_extend, xloc=xloc.bar_time)
    array.push(fib_lines, line_0)
    
    // 25% Line  
    line_25 = line.new(start_time, fib_25, end_time, fib_25,
                      color=fib_25_color, style=get_line_style(fib_25_line_style),
                      extend=line_extend, xloc=xloc.bar_time)
    array.push(fib_lines, line_25)
    
    // 50% Line
    line_50 = line.new(start_time, fib_50, end_time, fib_50,
                      color=fib_50_color, style=get_line_style(fib_50_line_style),
                      extend=line_extend, xloc=xloc.bar_time)
    array.push(fib_lines, line_50)
    
    // 75% Line
    line_75 = line.new(start_time, fib_75, end_time, fib_75,
                      color=fib_75_color, style=get_line_style(fib_75_line_style),
                      extend=line_extend, xloc=xloc.bar_time)
    array.push(fib_lines, line_75)
    
    // 100% Line
    line_100 = line.new(start_time, fib_100, end_time, fib_100,
                       color=fib_100_color, style=get_line_style(fib_100_line_style),
                       extend=line_extend, xloc=xloc.bar_time)
    array.push(fib_lines, line_100)
    
    // Add timeframe label if enabled
    if show_timeframe_fib_label
        tf_display = format_timeframe(tf_string)
        label_text = tf_display + ' Fib'
        tf_label = label.new(start_time, fib_0, text=label_text,
                           style=label.style_label_left, color=color.new(color.black, 80),
                           textcolor=color.white, size=size.small, xloc=xloc.bar_time)
        array.push(fib_labels, tf_label)

// =============================================================================
// FIBONACCI DRAWING LOGIC - CONFIRMED ENGULFING ONLY
// =============================================================================

// TF1 Fibonacci - Draw once when confirmed engulfing detected
if tf1_enabled and tf1_enable_fib and (tf1_bull_confirmed or tf1_bear_confirmed)
    if not tf1_fib_drawn or (tf1_bull_confirmed != tf1_bull_confirmed[1]) or (tf1_bear_confirmed != tf1_bear_confirmed[1])
        is_bullish = tf1_bull_confirmed
        
        // Get previous candle data (the confirmed engulfing candle)
        engulf_high = tf1_fib_high[1]
        engulf_low = tf1_fib_low[1]
        
        // Line timing: From start of engulfing candle to end of next candle
        start_time = tf1_fib_time[1]  // Start of engulfing candle
        end_time = tf1_fib_time_close  // End of current candle (next after engulfing)
        
        create_fibonacci_lines(is_bullish, engulf_high, engulf_low, start_time, end_time, tf1, tf1_fib_lines, tf1_fib_labels)
        tf1_fib_drawn := true
else
    tf1_fib_drawn := false

// TF2 Fibonacci - Draw once when confirmed engulfing detected  
if tf2_enabled and tf2_enable_fib and is_higher_timeframe(tf2) and not has_tf1_conflict(tf2) and (tf2_bull_confirmed or tf2_bear_confirmed)
    if not tf2_fib_drawn or (tf2_bull_confirmed != tf2_bull_confirmed[1]) or (tf2_bear_confirmed != tf2_bear_confirmed[1])
        is_bullish = tf2_bull_confirmed
        
        // Get previous candle data (the confirmed engulfing candle)
        engulf_high = tf2_fib_high[1]
        engulf_low = tf2_fib_low[1]
        
        // Line timing: From start of engulfing candle to end of next candle
        start_time = tf2_fib_time[1]  // Start of engulfing candle
        end_time = tf2_fib_time_close  // End of current candle (next after engulfing)
        
        create_fibonacci_lines(is_bullish, engulf_high, engulf_low, start_time, end_time, tf2, tf2_fib_lines, tf2_fib_labels)
        tf2_fib_drawn := true
else
    tf2_fib_drawn := false

// TF3 Fibonacci - Draw once when confirmed engulfing detected
if tf3_enabled and tf3_enable_fib and is_higher_timeframe(tf3) and not has_tf1_conflict(tf3) and (tf3_bull_confirmed or tf3_bear_confirmed)    
    if not tf3_fib_drawn or (tf3_bull_confirmed != tf3_bull_confirmed[1]) or (tf3_bear_confirmed != tf3_bear_confirmed[1])
        is_bullish = tf3_bull_confirmed
        
        // Get previous candle data (the confirmed engulfing candle)
        engulf_high = tf3_fib_high[1]
        engulf_low = tf3_fib_low[1]
        
        // Line timing: From start of engulfing candle to end of next candle
        start_time = tf3_fib_time[1]  // Start of engulfing candle  
        end_time = tf3_fib_time_close  // End of current candle (next after engulfing)
        
        create_fibonacci_lines(is_bullish, engulf_high, engulf_low, start_time, end_time, tf3, tf3_fib_lines, tf3_fib_labels)
        tf3_fib_drawn := true
else
    tf3_fib_drawn := false

// TF4 Fibonacci - Draw once when confirmed engulfing detected
if tf4_enabled and tf4_enable_fib and is_higher_timeframe(tf4) and not has_tf1_conflict(tf4) and (tf4_bull_confirmed or tf4_bear_confirmed)    
    if not tf4_fib_drawn or (tf4_bull_confirmed != tf4_bull_confirmed[1]) or (tf4_bear_confirmed != tf4_bear_confirmed[1])
        is_bullish = tf4_bull_confirmed
        
        // Get previous candle data (the confirmed engulfing candle)
        engulf_high = tf4_fib_high[1]
        engulf_low = tf4_fib_low[1]
        
        // Line timing: From start of engulfing candle to end of next candle
        start_time = tf4_fib_time[1]  // Start of engulfing candle  
        end_time = tf4_fib_time_close  // End of current candle (next after engulfing)
        
        create_fibonacci_lines(is_bullish, engulf_high, engulf_low, start_time, end_time, tf4, tf4_fib_lines, tf4_fib_labels)
        tf4_fib_drawn := true
else
    tf4_fib_drawn := false

// TF5 Fibonacci - Draw once when confirmed engulfing detected
if tf5_enabled and tf5_enable_fib and is_higher_timeframe(tf5) and not has_tf1_conflict(tf5) and (tf5_bull_confirmed or tf5_bear_confirmed)    
    if not tf5_fib_drawn or (tf5_bull_confirmed != tf5_bull_confirmed[1]) or (tf5_bear_confirmed != tf5_bear_confirmed[1])
        is_bullish = tf5_bull_confirmed
        
        // Get previous candle data (the confirmed engulfing candle)
        engulf_high = tf5_fib_high[1]
        engulf_low = tf5_fib_low[1]
        
        // Line timing: From start of engulfing candle to end of next candle
        start_time = tf5_fib_time[1]  // Start of engulfing candle  
        end_time = tf5_fib_time_close  // End of current candle (next after engulfing)
        
        create_fibonacci_lines(is_bullish, engulf_high, engulf_low, start_time, end_time, tf5, tf5_fib_lines, tf5_fib_labels)
        tf5_fib_drawn := true
else
    tf5_fib_drawn := false

// TF6 Fibonacci - Draw once when confirmed engulfing detected
if tf6_enabled and tf6_enable_fib and is_higher_timeframe(tf6) and not has_tf1_conflict(tf6) and (tf6_bull_confirmed or tf6_bear_confirmed)    
    if not tf6_fib_drawn or (tf6_bull_confirmed != tf6_bull_confirmed[1]) or (tf6_bear_confirmed != tf6_bear_confirmed[1])
        is_bullish = tf6_bull_confirmed
        
        // Get previous candle data (the confirmed engulfing candle)
        engulf_high = tf6_fib_high[1]
        engulf_low = tf6_fib_low[1]
        
        // Line timing: From start of engulfing candle to end of next candle
        start_time = tf6_fib_time[1]  // Start of engulfing candle  
        end_time = tf6_fib_time_close  // End of current candle (next after engulfing)
        
        create_fibonacci_lines(is_bullish, engulf_high, engulf_low, start_time, end_time, tf6, tf6_fib_lines, tf6_fib_labels)
        tf6_fib_drawn := true
else
    tf6_fib_drawn := false



// =============================================================================
// ALERTS
// =============================================================================

// Helper function to build JSON alert string
build_alert_json(timeframe_str, direction_str) =>
    '{"symbol":"' + syminfo.tickerid + '","timeframe":"' + timeframe_str + '","time":"' + str.tostring(time) + '","direction":"' + direction_str + '","chartId":"' + chartId + '"}'

// TF1 Alerts
if tf1_enabled and tf1_bull_confirmed and not tf1_bull_confirmed[1]
    alert(build_alert_json(format_timeframe(tf1), "Bullish"), alert.freq_once_per_bar)

if tf1_enabled and tf1_bear_confirmed and not tf1_bear_confirmed[1]
    alert(build_alert_json(format_timeframe(tf1), "Bearish"), alert.freq_once_per_bar)

// TF2 Alerts
if tf2_enabled and is_higher_timeframe(tf2) and not has_tf1_conflict(tf2) and tf2_bull_confirmed and not tf2_bull_confirmed[1]
    alert(build_alert_json(format_timeframe(tf2), "Bullish"), alert.freq_once_per_bar)

if tf2_enabled and is_higher_timeframe(tf2) and not has_tf1_conflict(tf2) and tf2_bear_confirmed and not tf2_bear_confirmed[1]
    alert(build_alert_json(format_timeframe(tf2), "Bearish"), alert.freq_once_per_bar)

// TF3 Alerts
if tf3_enabled and is_higher_timeframe(tf3) and not has_tf1_conflict(tf3) and tf3_bull_confirmed and not tf3_bull_confirmed[1]
    alert(build_alert_json(format_timeframe(tf3), "Bullish"), alert.freq_once_per_bar)

if tf3_enabled and is_higher_timeframe(tf3) and not has_tf1_conflict(tf3) and tf3_bear_confirmed and not tf3_bear_confirmed[1]
    alert(build_alert_json(format_timeframe(tf3), "Bearish"), alert.freq_once_per_bar)

// TF4 Alerts
if tf4_enabled and is_higher_timeframe(tf4) and not has_tf1_conflict(tf4) and tf4_bull_confirmed and not tf4_bull_confirmed[1]
    alert(build_alert_json(format_timeframe(tf4), "Bullish"), alert.freq_once_per_bar)

if tf4_enabled and is_higher_timeframe(tf4) and not has_tf1_conflict(tf4) and tf4_bear_confirmed and not tf4_bear_confirmed[1]
    alert(build_alert_json(format_timeframe(tf4), "Bearish"), alert.freq_once_per_bar)

// TF5 Alerts
if tf5_enabled and is_higher_timeframe(tf5) and not has_tf1_conflict(tf5) and tf5_bull_confirmed and not tf5_bull_confirmed[1]
    alert(build_alert_json(format_timeframe(tf5), "Bullish"), alert.freq_once_per_bar)

if tf5_enabled and is_higher_timeframe(tf5) and not has_tf1_conflict(tf5) and tf5_bear_confirmed and not tf5_bear_confirmed[1]
    alert(build_alert_json(format_timeframe(tf5), "Bearish"), alert.freq_once_per_bar)

// TF6 Alerts
if tf6_enabled and is_higher_timeframe(tf6) and not has_tf1_conflict(tf6) and tf6_bull_confirmed and not tf6_bull_confirmed[1]
    alert(build_alert_json(format_timeframe(tf6), "Bullish"), alert.freq_once_per_bar)

if tf6_enabled and is_higher_timeframe(tf6) and not has_tf1_conflict(tf6) and tf6_bear_confirmed and not tf6_bear_confirmed[1]
    alert(build_alert_json(format_timeframe(tf6), "Bearish"), alert.freq_once_per_bar)

//Explanation of the code:
// 🔥 Liquidity Engulfing Multi-Timeframe Detector
// This indicator finds engulfing bars which have swept liquidity from its previous candle. You can use it across 6 timeframes with fibonacci entries.

// ⚡ Key Features
// 6 Customizable Timeframes - Complete market structure analysis
// Smart Liquidity Detection - Finds patterns that sweep liquidity then reverse
// Real-Time Status Table - Confirmed vs unconfirmed patterns with color coding
// Fibonacci Integration - 5 customizable fib levels for precise entries
// HTF → LTF Strategy - Spot reversals on higher timeframes, enter on lower timeframe fibs


// 📈 Engulfing Rules
// Bullish: Current candle bullish + previous bearish + current low < previous low + current close > previous open
// Bearish: Current candle bearish + previous bullish + current high > previous high + current close < previous open